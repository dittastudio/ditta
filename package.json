{
  "name": "ditta",
  "private": true,
  "type": "module",
  "scripts": {
    "sb:login": "storyblok login",
    "sb:logout": "storyblok logout",
    "sb:help": "storyblok --help",
    "sb:components": "storyblok components pull --space 284609 --verbose",
    "sb:types": "storyblok types generate --space 284609 --strict",
    "sb:generate": "npm run sb:components && npm run sb:types",
    "create:icons": "npx nuxt-seo-utils icons --source ./favicon.svg",
    "dev": "npm run sb:generate && nuxt dev --host 0.0.0.0",
    "dev:ssl": "local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "nuke": "del-cli '.output' 'dist' '.nuxt' 'node_modules' 'package-lock.json'",
    "prepare": "vp config"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@storyblok/nuxt": "^10.1.4",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "matter-js": "^0.20.0",
    "nuxt": "^4.4.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/matter-js": "^0.20.2",
    "del-cli": "^7.0.0",
    "postcss-nested": "^7.0.2",
    "postcss-utopia": "^1.1.0",
    "rolldown": "^1.0.0-rc.18",
    "storyblok": "^4.17.2",
    "tailwindcss": "^4.2.4",
    "vite-plus": "latest",
    "vite-svg-loader": "^5.1.1"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.13.0"
}
