{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "sb:components": "storyblok components pull --space 284609",
    "sb:types": "storyblok types generate --space 284609 --strict",
    "dev": "npm run sb:components && npm run sb:types && nuxt dev --host",
    "dev:ssl": "local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nuke": "del-cli '.output' 'dist' '.nuxt' 'node_modules' 'package-lock.json'"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@nuxt/scripts": "^0.11.13",
    "@storyblok/nuxt": "^7.0.1",
    "@tailwindcss/vite": "^4.1.12",
    "@unhead/vue": "^2.0.14",
    "eslint": "^9.33.0",
    "gsap": "^3.13.0",
    "lodash-es": "^4.17.21",
    "nuxt": "^4.0.3",
    "tailwindcss": "^4.1.12",
    "vue": "^3.5.19",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.1",
    "@nuxt/image": "^1.11.0",
    "@nuxtjs/sitemap": "^7.4.3",
    "@types/lodash-es": "^4.17.12",
    "del-cli": "^6.0.0",
    "postcss-nested": "^7.0.2",
    "postcss-utopia": "^1.1.0",
    "storyblok": "^4.3.4",
    "typescript": "^5.9.2",
    "vite-svg-loader": "^5.1.0"
  }
}
